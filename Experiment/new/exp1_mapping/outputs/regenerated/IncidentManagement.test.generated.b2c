contract IncidentManagement {

    participants {
        participant Participant_15d83ih {
            msp "VIP_CustomerMSP"
            x509 ""
            isMulti false
            multiMin 0
            multiMax 0
            attributes {
                role = "VIP Customer"

            }
        }
        participant Participant_1yxjs7i {
            msp "Key_Account_ManagerMSP"
            x509 ""
            isMulti false
            multiMin 0
            multiMax 0
            attributes {
                role = "Key Account Manager"

            }
        }
        participant Participant_123vwrd {
            msp "1st_level_support_agentMSP"
            x509 ""
            isMulti false
            multiMin 0
            multiMax 0
            attributes {
                role = "1st level support agent"

            }
        }
        participant Participant_19fntjv {
            msp "2nd_level_support_agentMSP"
            x509 ""
            isMulti false
            multiMin 0
            multiMax 0
            attributes {
                role = "2nd level support agent"

            }
        }
        participant Participant_01r48ub {
            msp "Software_developerMSP"
            x509 ""
            isMulti false
            multiMin 0
            multiMax 0
            attributes {
                role = "Software developer"

            }
        }

    }



    globals {
        Answer: string
        Dev_issue: string
        Feedback: string
        First_issue: string
        Handle: bool
        Problem: string
        Second_issue: string
        Solution: string

    }



    messages {
        message Message_05qx9bx from Participant_1yxjs7i to Participant_123vwrd {
            initial state INACTIVE
            schema "{\"properties\":{\"first_issue\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_0bvz0t0 from Participant_123vwrd to Participant_19fntjv {
            initial state INACTIVE
            schema "{\"properties\":{\"second_issue\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_0ek1csx from Participant_15d83ih to Participant_1yxjs7i {
            initial state INACTIVE
            schema "{}"
        }
        message Message_0meslzn from Participant_1yxjs7i to Participant_15d83ih {
            initial state INACTIVE
            schema "{\"properties\":{\"solution\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_0r74t0d from Participant_19fntjv to Participant_01r48ub {
            initial state INACTIVE
            schema "{\"properties\":{\"dev_issue\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_0tfcf0f from Participant_123vwrd to Participant_1yxjs7i {
            initial state INACTIVE
            schema "{\"properties\":{\"feedback\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_0x3m7cv from Participant_19fntjv to Participant_123vwrd {
            initial state INACTIVE
            schema "{\"properties\":{\"feedback\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_0zg86is from Participant_01r48ub to Participant_19fntjv {
            initial state INACTIVE
            schema "{\"properties\":{\"feedback\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_19uhzjz from Participant_15d83ih to Participant_1yxjs7i {
            initial state INACTIVE
            schema "{\"properties\":{\"answer\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_1c9wwae from Participant_123vwrd to Participant_1yxjs7i {
            initial state INACTIVE
            schema "{}"
        }
        message Message_1j8ntet from Participant_15d83ih to Participant_1yxjs7i {
            initial state INACTIVE
            schema "{\"properties\":{\"problem\":{\"type\":\"string\",\"description\":\"\"}},\"required\":[],\"files\":{},\"file required\":[]}"
        }
        message Message_1k8bc91 from Participant_1yxjs7i to Participant_15d83ih {
            initial state INACTIVE
            schema "{}"
        }

    }



    gateways {
        gateway Gateway_0xhpdxq {
            type exclusive
            initial state INACTIVE
        }
        gateway Gateway_0a3xut0 {
            type exclusive
            initial state INACTIVE
        }
        gateway Gateway_1lr7zva {
            type exclusive
            initial state INACTIVE
        }

    }



    events {
        event Event_026jxk6 {
            initial state READY
        }
        event Event_18807k4 {
            initial state INACTIVE
        }

    }



    businessrules {

    }



    oracletasks {

    }



    flows {
        start event Event_026jxk6 enables Message_1j8ntet;

        when message Message_1j8ntet completed
        then enable Message_19uhzjz;
        when message Message_19uhzjz completed
        then enable Message_1k8bc91;
        when message Message_1k8bc91 completed
        then enable Gateway_0xhpdxq;
        when message Message_0meslzn completed
        then enable Message_0ek1csx;
        when message Message_0ek1csx completed
        then enable Event_18807k4;
        when message Message_05qx9bx completed
        then enable Message_1c9wwae;
        when message Message_1c9wwae completed
        then enable Gateway_0a3xut0;
        when message Message_0tfcf0f completed
        then enable Message_0meslzn;
        when message Message_0bvz0t0 completed
        then enable Gateway_1lr7zva;
        when message Message_0x3m7cv completed
        then enable Message_0tfcf0f;
        when message Message_0r74t0d completed
        then enable Message_0zg86is;
        when message Message_0zg86is completed
        then enable Message_0x3m7cv;

        when gateway Gateway_0xhpdxq completed
        choose {
            if Handle == true
            then enable Message_0meslzn;
            if Handle == false
            then enable Message_05qx9bx;

        }
        when gateway Gateway_0a3xut0 completed
        then enable Message_0tfcf0f, enable Message_0bvz0t0;
        when gateway Gateway_1lr7zva completed
        then enable Message_0x3m7cv, enable Message_0r74t0d;

    }

}
