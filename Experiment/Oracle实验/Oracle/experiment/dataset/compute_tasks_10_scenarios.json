          "onchain_supported": false,
          "inputs": {
            "seed": 20260304,
            "draws": 4000,
            "alert_prob": 0.13
          },
          "js_expression": "let state=seed; let hit=0; for(let i=0;i<draws;i++){state=(state*48271)%2147483647; const u=(state%10000)/10000; if(u<alertProb) hit++;} const conf=Math.round(hit*1e6/draws);"
