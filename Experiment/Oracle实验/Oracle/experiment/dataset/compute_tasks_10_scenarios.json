            "y_min": 0,
            "y_max": 10,
            "z_min": 0,
            "z_max": 10
          },
          "js_expression": "for x in [x_min..x_max..step], y in [y_min..y_max..step], z in [z_min..z_max..step]: score=60*x+25*y+15*z; cost=400*x+120*y+80*z; objective=(score-target_score)^2 + 2*(cost-budget)^2; result=min(objective)"
