    <bpmn2:textAnnotation id="TextAnnotation_0ics2kf">
      <bpmn2:text>同一批次的原料作为一种FT资产</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_14der5j" sourceRef="ChoreographyTask_19739o8" targetRef="TextAnnotation_0ics2kf" />
    <bpmn2:textAnnotation id="TextAnnotation_14qsb8t">
      <bpmn2:text>每个产品作为一个NFT，以达到溯源</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_09a5u8p" sourceRef="ChoreographyTask_0vlscoh" targetRef="TextAnnotation_14qsb8t" />
    <bpmn2:textAnnotation id="TextAnnotation_053eat4">
      <bpmn2:text>统一原料FT转移所属权</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_148a6qt" sourceRef="ChoreographyTask_00i36zz" targetRef="TextAnnotation_053eat4" />
    <bpmn2:textAnnotation id="TextAnnotation_10un6le">
      <bpmn2:text>产品NFT转移所属权到买家</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_152p4bc" sourceRef="ChoreographyTask_0cxxmys" targetRef="TextAnnotation_10un6le" />
    <bpmn2:textAnnotation id="TextAnnotation_1fbqasw">
      <bpmn2:text>将原料批次作为FT，产品作为NFT，实现用户根据某个产品进行溯源，到具体原料，然后买家就能用查询操作进行产品溯源</bpmn2:text>
    </bpmn2:textAnnotation>
