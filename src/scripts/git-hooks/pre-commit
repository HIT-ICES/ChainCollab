#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "${REPO_ROOT}" ]; then
  echo "[pre-commit] not inside a git repository"
  exit 1
fi

cd "${REPO_ROOT}"

if [ ! -x "./src/devtools.sh" ]; then
  echo "[pre-commit] missing executable: ./src/devtools.sh"
  exit 1
fi

echo "[pre-commit] running governance-check..."
./src/devtools.sh governance-check

echo "[pre-commit] governance-check passed"
